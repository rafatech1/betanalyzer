# Anthropic (Claude) — análise qualitativa e síntese de IA
ANTHROPIC_API_KEY=

# API-Football — usada hoje só como contexto extra (H2H e lesões) na análise,
# não mais para a listagem de jogos (o plano gratuito não cobre a temporada
# atual). Fonte principal de fixtures: The Odds API (ver ODDS_API_SPORT_KEYS).
API_FOOTBALL_KEY=

# Temporada fixa para chamadas à API-Football (opcional). Sem isso, o cálculo
# automático de temporada pode apontar para 2025/2026, que o plano gratuito
# não acessa — defina para a última temporada coberta pelo seu plano.
# Ex.: FOOTBALL_SEASON=2024
FOOTBALL_SEASON=

# The Odds API — fonte principal de jogos (fixtures) e odds das casas de apostas
ODDS_API_KEY=

# IDs de ligas da API-Football a monitorar (formato JSON) — usado apenas se
# você reativar a listagem de jogos via API-Football manualmente; o job
# automático de fixtures não depende mais disso. Ex.: MONITORED_LEAGUE_IDS=[71,39]
MONITORED_LEAGUE_IDS=[]

# Chaves de esporte/liga da The Odds API a consultar (formato JSON) — define
# de quais ligas o job automático busca jogos e odds.
# Ex.: ODDS_API_SPORT_KEYS=["soccer_brazil_campeonato","soccer_epl"]
ODDS_API_SPORT_KEYS=[]

# Ligas (IDs da API-Football) cujos jogos das próximas 24h são pré-analisados
# automaticamente pelo job do scheduler (formato JSON). Ex.: [71,39]
PRE_ANALYSIS_LEAGUE_IDS=[]

# Banco de dados (usado pelo backend dentro do docker-compose)
POSTGRES_USER=betanalyzer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=betanalyzer
DATABASE_URL=postgresql+asyncpg://betanalyzer:changeme@postgres:5432/betanalyzer

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Geral
ENVIRONMENT=development
LOG_LEVEL=INFO

# Origens permitidas para CORS. Em produção, restrinja ao(s) domínio(s) reais
# do frontend — nunca use "*" com allow_credentials=True. Aceita JSON
# (preferido) ou uma lista separada por vírgulas como fallback. NÃO inclua
# barra final na URL (o header Origin do browser nunca tem "/" no final —
# uma barra sobrando faz o CORSMiddleware rejeitar o preflight com 400).
# Ex.: CORS_ORIGINS=["https://app.seudominio.com"]
CORS_ORIGINS=["http://localhost:3000"]

# Autenticação JWT — GERE uma chave forte e aleatória em produção, nunca
# reaproveite o valor de desenvolvimento. Ex.: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Marque o cookie de refresh token como Secure (exigido em produção, já que
# o acesso é sempre via HTTPS atrás do proxy). Em dev local sem HTTPS, deixe false.
REFRESH_COOKIE_SECURE=false

# Seed do usuário admin (uso pessoal, sem cadastro aberto). Preenchido apenas
# na primeira execução — se o usuário já existir, o seed é ignorado.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Rate limiting de login (tentativas por IP).
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_LOCKOUT_SECONDS=300

# Nome da rede Docker externa do Nginx Proxy Manager (usada apenas em
# docker-compose.prod.yml, para o NPM alcançar backend/frontend pelo nome
# do serviço sem expor portas no host). Descubra com: docker network ls
NPM_NETWORK_NAME=npm_network
